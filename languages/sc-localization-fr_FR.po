msgstr "Groupe %s"

#: frontend/shortcode.php:43
msgid "1. Definer Komponent Format"
msgstr "1. Définir le format des composants"

#: frontend/shortcode.php:46
msgid "Byg dit format ved at trække elementerne (chips) herunder ned i det blå område.<br/>Du kan også klikke på knapperne for at tilføje mellemrum eller bindestreger."
msgstr "Créez votre format en faisant glisser les éléments (puces) ci-dessous dans la zone bleue.<br/>Vous pouvez également cliquer sur les boutons pour ajouter des espaces ou des tirets."

#: frontend/shortcode.php:49
msgid "Indlæs din opsætning fra sidste patch"
msgstr "Charger votre configuration du dernier patch"

#: frontend/shortcode.php:56
msgid "Type:"
msgstr "Type :"

#: frontend/shortcode.php:57
msgid "COOL eller C for Cooler<br/>POWR eller P for Powerplant<br/>SHLD eller S for Shield<br/>QDRV eller Q for Quantumdrive<br/>RADR eller R for Radar"
msgstr "COOL ou C pour Cooler (Refroidisseur)<br/>POWR ou P pour Powerplant (Générateur)<br/>SHLD ou S pour Shield (Bouclier)<br/>QDRV ou Q pour Quantumdrive (Propulseur Quantique)<br/>RADR ou R pour Radar"

#: frontend/shortcode.php:62
msgid "Klassificering:"
msgstr "Classification :"

#: frontend/shortcode.php:63
msgid "CIV eller C (Civilian)<br/>CMP eller R (Competition/Racing)<br/>IND eller I (Industriel)<br/>MIL eller M (Military)<br/>STL eller S (Stealth)"
msgstr "CIV ou C (Civil)<br/>CMP ou R (Compétition/Course)<br/>IND ou I (Industriel)<br/>MIL ou M (Militaire)<br/>STL ou S (Furtif)"

#: frontend/shortcode.php:68
msgid "Størrelse:"
msgstr "Taille :"

#: frontend/shortcode.php:68
msgid "1, 2, 3 osv."
msgstr "1, 2, 3 etc."

#: frontend/shortcode.php:69
msgid "Kvalitet:"
msgstr "Qualité :"

#: frontend/shortcode.php:69
msgid "A, B, C, D."
msgstr "A, B, C, D."

