msgstr "ex. C, P"

#: frontend/shortcode.php:78
msgid "Type (1 tegn)"
msgstr "Type (1 caractère)"

#: frontend/shortcode.php:79
msgid "F.eks. MIL, STL"
msgstr "ex. MIL, STL"

#: frontend/shortcode.php:79
