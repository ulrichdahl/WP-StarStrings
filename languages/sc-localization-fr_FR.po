#: frontend/shortcode.php:11
msgid "Der er ikke uploadet de nødvendige filer for at vi kan lave Star Citizen lokalisering endnu."
msgstr "Les fichiers nécessaires à la localisation de Star Citizen n'ont pas encore été téléchargés."

#: frontend/shortcode.php:26
msgid "Er du sikker på, at du vil nulstille sorteringen? Alle valgte fartøjer flyttes tilbage."
msgstr "Êtes-vous sûr de vouloir réinitialiser le tri ? Tous les véhicules sélectionnés seront déplacés en arrière."

#: frontend/shortcode.php:27
msgid "Indtast adskillelsestegn:"
msgstr "Entrez le séparateur :"

#: frontend/shortcode.php:28
msgid "Vælg venligst et format til komponenter."
msgstr "Veuillez choisir un format pour les composants."

#: frontend/shortcode.php:29
msgid "Opsætningen er indlæst!"
msgstr "La configuration a été chargée !"

#: frontend/shortcode.php:30
msgid "Fejl: Filen er ikke en gyldig JSON-fil."
msgstr "Erreur : Le fichier n'est pas un fichier JSON valide."

