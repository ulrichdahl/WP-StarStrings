msgstr "Classification (3 caractères)"

#: frontend/shortcode.php:80
msgid "F.eks. M, S"
msgstr "ex. M, S"

#: frontend/shortcode.php:80
msgid "Klassificering (1 tegn)"
msgstr "Classification (1 caractère)"

#: frontend/shortcode.php:81
msgid "F.eks. S1, S2"
msgstr "ex. S1, S2"

#: frontend/shortcode.php:81
msgid "Størrelse"
msgstr "Taille"

#: frontend/shortcode.php:82
msgid "F.eks. A, B"
msgstr "ex. A, B"

#: frontend/shortcode.php:82
msgid "Kvalitet"
msgstr "Qualité"

#: frontend/shortcode.php:83
msgid "Selve navnet på komponenten"
msgstr "Le nom du composant lui-même"

#: frontend/shortcode.php:83
msgid "Navn"
msgstr "Nom"

